private ["_nom","_precio","_preciofinal"];
	_index = 0;
	_asegurado = false;
	while {_index < (count _coches)} do {

	if (typeOf _vehicle == _coches select _index select 0) exitWith {
		_asegurado = true;
	};
		_index = _index + 1;
	};

	if (_asegurado) then {
	_nom = [_coches select _index select 0] call ica_fnc_classToName;
	_precio = (_coches select _index select 1); 
	_preciofinal = _precio * 0.1;
	if (pop_din < _preciofinal) exitwith {hint format ["La poliza de seguro para tu %1 cuesta %2€, lo siento solo acepto pagos en efectivo",_nom,_preciofinal]};
	pop_din = pop_din - _preciofinal;
	_vehicle setVariable ["asegurado",1,true];
	_vehicle setVariable["isInsured",true,true];
	[[_vehicle],"TON_fnc_vehicleInsurance",false,false] call life_fnc_MP;

	hint format ["Gracias, has comprado una poliza de seguro para tu %1 por un valor de %2€, Quizas nos tardemos pero te devolveremos el coche en caso de que lo pierdas, eso si no respondemos si lo mandas al garaje.",_nom,_preciofinal];
	} else {
	hint "Lo sentimos ... este coche no puede o quizas ni merezca ser asegurado ... traenos otro que valga la pena y con mucho gusto.";
	};

};